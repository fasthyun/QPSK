options:
  parameters:
    author: hyun
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: ''
    copyright: ''
    description: ''
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: psk8_create_v1
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: Not titled yet
    window_size: (1000,1000)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: epsilon
  id: variable_qtgui_range
  parameters:
    comment: 'Sets timing difference

      between transmitter

      and receiver due to

      variations in clocks.'
    gui_hint: 0,10,1,10
    label: 'Channel: Timing Offset'
    min_len: '200'
    orient: Qt.Horizontal
    rangeType: float
    start: '0.999'
    step: '0.0001'
    stop: '1.001'
    value: '1.000'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [715, 24]
    rotation: 0
    state: enabled
- name: excess_bw
  id: variable
  parameters:
    comment: '# Power spectrum

      * 0.35: same to origin

      * 0.7 :  outside removed to origin

      * 0.87 :  more outside removed to origin


      # Constellation

      * 0.35: ok

      * 0.7 :  slim

      * 0.87 :  sharp'
    value: 0.35*1
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [353, 108]
    rotation: 0
    state: enabled
- name: freq_offset
  id: variable_qtgui_range
  parameters:
    comment: 'This accounts for differences

      in local oscillators as well as

      static Doppler shift.'
    gui_hint: 1,0,1,10
    label: 'Channel: Frequency Offset'
    min_len: '200'
    orient: Qt.Horizontal
    rangeType: float
    start: '-0.1'
    step: '0.001'
    stop: '0.1'
    value: '0.0'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [931, 20]
    rotation: 0
    state: enabled
- name: noise_volt
  id: variable_qtgui_range
  parameters:
    comment: 'Sets noise level of added

      Gaussian white noise (AWGN)

      added during transmission

      as well as antenna noise and

      LNA of receiver.'
    gui_hint: 0,0,1,10
    label: 'Channel: Noise Voltage'
    min_len: '200'
    orient: Qt.Horizontal
    rangeType: float
    start: '0'
    step: '0.01'
    stop: '1'
    value: '0.0'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [490, 20]
    rotation: 0
    state: enabled
- name: phase_bw
  id: variable
  parameters:
    comment: ''
    value: 0.0628/2
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [234, 100]
    rotation: 0
    state: enabled
- name: psk8
  id: variable_constellation
  parameters:
    comment: ''
    const_points: '[1.00 + 0.00j, 0.71 + 0.71j, 0.00 + 1.00j,  -0.71 + 0.71j, -1.00
      + 0.00j, -0.71 -0.71j, -0.00 -1.00j, 0.71 -0.71j]'
    dims: '1'
    precision: '8'
    rot_sym: '4'
    soft_dec_lut: None
    sym_map: '[0, 1, 2, 3, 4, 5, 6, 7]'
    type: 8psk
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [295, 412]
    rotation: 0
    state: enabled
- name: samp_rate
  id: variable
  parameters:
    comment: ''
    value: '9600'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [229, 17]
    rotation: 0
    state: enabled
- name: sps
  id: variable
  parameters:
    comment: ''
    value: '8'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [355, 22]
    rotation: 0
    state: enabled
- name: var_filter_taps
  id: variable_low_pass_filter_taps
  parameters:
    beta: '6.76'
    comment: ''
    cutoff_freq: 2000-100
    gain: '1.0'
    samp_rate: samp_rate
    width: '80'
    win: firdes.WIN_HAMMING
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1178, 43]
    rotation: 0
    state: disabled
- name: var_filter_taps
  id: variable_rrc_filter_taps
  parameters:
    alpha: 0.35*1
    comment: "better than LPF\n\uB300\uC5EC\uD3ED \uBC14\uB85C \uBC14\uAE65\uC744\
      \ \uB354 \uB9CE\uC774 \uCCD0\uBC84\uB9BC"
    gain: '1.0'
    ntaps: 11*sps
    samp_rate: samp_rate
    sym_rate: samp_rate/sps
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1144, 336.0]
    rotation: 0
    state: enabled
- name: analog_random_source_x_0
  id: analog_random_source_x
  parameters:
    affinity: ''
    alias: ''
    comment: ''
    max: '256'
    maxoutbuf: '0'
    min: '0'
    minoutbuf: '0'
    num_samps: '1024'
    repeat: 'True'
    type: byte
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [0, 209]
    rotation: 0
    state: enabled
